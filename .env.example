# =============================================================================
# BOTinok Configuration Example
# =============================================================================
# GitHub: https://github.com/ShavlaK/BOTinok
# =============================================================================
# Скопируйте этот файл в .env и заполните обязательные поля
# =============================================================================

# =============================================================================
# ОБЯЗАТЕЛЬНЫЕ ПАРАМЕТРЫ
# =============================================================================

# Токен бота Telegram (получить в @BotFather)
# Пример: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TOKEN_MAIN=''

# ID Telegram администратора (узнать в @userinfobot)
# Пример: 123456789
MY_ID_TELEG=

# =============================================================================
# ОСНОВНЫЕ НАСТРОЙКИ
# =============================================================================

# Ник для поддержки (без @)
NICK_HELP='codenlx'

# Имя автора VPN
NAME_AUTHOR_VPN='Александр'

# Название бота для конфигов (только буквы и цифры)
NAME_VPN_CONFIG='VPCoden'

# Порт 3X-UI панели (указывается автоматически при установке)
X3_UI_PORT_PANEL=

# =============================================================================
# ПРОТОКОЛЫ (True/False)
# =============================================================================

PR_VLESS=True           # ✅ VLESS - современный протокол
PR_OUTLINE=False        # ❌ Outline - отключен
PR_WIREGUARD=False      # ❌ WireGuard - отключен
PR_PPTP=False           # ❌ PPTP - отключен

# =============================================================================
# ФУНКЦИИ (True/False)
# =============================================================================

# Тестовые ключи
TEST_KEY=True

# Реферальная система
REF_SYSTEM=True
REF_SYSTEM_AFTER_PAY=False  # Начисление дней только после оплаты

# Платёжная система
OPLATA=True

# Донаты
DONATE_SYSTEM=True
WHY_VPN_PAY=True

# Обещанный платеж (+1 день раз в месяц)
OBESH_PLATEZH=True

# QR-коды (не используется для VLESS)
SEND_QR=False

# Inline режим кнопок
INLINE_MODE=False

# Отчёты
IS_OTCHET=False

# Подписка за подписку на каналы
PODPISKA_MODE=False

# =============================================================================
# ТАРИФЫ (рубли)
# =============================================================================
# Укажите 0 чтобы отключить тариф

TARIF_1=149             # 1 месяц
TARIF_3=379             # 3 месяца
TARIF_6=749             # 6 месяцев
TARIF_12=1349           # 12 месяцев

# =============================================================================
# РЕФЕРАЛЬНАЯ СИСТЕМА
# =============================================================================

# Дней пробного периода
COUNT_DAYS_TRIAL=2

# Дней доступа за приглашённого
COUNT_DAYS_REF=7

# Процент партнёра от оплаты (%)
PARTNER_P=30

# Минимальная сумма для вывода (рубли)
SUMM_VIVOD=200

# =============================================================================
# ПЛАТЁЖНЫЕ СИСТЕМЫ
# =============================================================================
# Заполните данные для нужных платёжных систем

# YooMoney
YOOMONEY_WALLET=''

# YooKassa
YOOKASSA_SHOP_ID=''
YOOKASSA_SECRET_KEY=''

# Tinkoff
TINKOFF_TERMINAL_KEY=''
TINKOFF_SECRET_KEY=''

# Cryptomus
CRYPTOMUS_API_KEY=''

# Wallet Pay
WALLET_PAY_API_KEY=''

# =============================================================================
# ДОПОЛНИТЕЛЬНО
# =============================================================================

# Курс доллара (для конвертации)
KURS_RUB=94

# Курс USDT
KURS_XTR=2

# Название локации по умолчанию
DEFAULT_LOCATION='🇳🇱Нидерланды'

# Язык по умолчанию
LANG_DEFAULT='Русский'
